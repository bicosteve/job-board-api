# ===== Flask & App =====
ENV=dev                     # Options: dev, prod, docker
DEBUG=True                  # True for dev, False for prod
HOST=127.0.0.1
PORT=5005

# ===== Database (MySQL) =====
DB_HOST=127.0.0.1           # Use 'db' if running in Docker compose
DB_USER=bico
DB_PASSWORD=
DB_NAME=job-board-api
DB_PORT=3306

# ===== Redis =====
REDIS_HOST=localhost        # Use 'redis' if running in Docker compose
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# RABBITMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# ===== JWT Settings =====
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_TOKEN_EXPIRY_HOURS=48

# ===== API Documentation =====
API_VERSION=1.0.0
API_VERSION_BASE=/job-board-api/v1/api
CONTACT_NAME=bicosteve
CONTACT_EMAIL=

# ===== Networking / Docker (optional) =====
SUBNET=172.25.0.0/24

# ===== Hosts ====
RENDER_EXTERNAL_HOSTNAME=
SERVER_HOST=



# ===== Mails
SENDGRID_API_KEY=
EMAIL_FROM=
MAILGUN_DOMAIN=
MAILGUN_API_KEY=
MAILGUN_BASE_URL=https://api.mailgun.net/v3

HEALTHCHECK_PATH=/job-board-api/v1/api/health/check
