# ===== Flask & App =====
ENV=dev                     # Options: dev, prod, docker
FLASK_ENV=development       # dev or production
DEBUG=True                  # True for dev, False for prod
HOST=127.0.0.1
PORT=5005

# ===== Database (MySQL) =====
DB_HOST=127.0.0.1           # Use 'db' if running in Docker compose
DB_USER=**
DB_PASSWORD=***
DB_NAME=job_board_api
DB_PORT=3306

# ===== Redis =====
REDIS_HOST=localhost        # Use 'redis' if running in Docker compose
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=1234

# ===== Rate Limiting (auth endpoints) =====
RATELIMIT_ENABLED=true          # master on/off switch
RATELIMIT_FAIL_OPEN=true        # if Redis is down, allow requests through
RATELIMIT_STRATEGY=fixed-window # fixed-window | moving-window | fixed-window-elastic-expiry
# Defaults to redis://[:password@]REDIS_HOST:REDIS_PORT/REDIS_DB when unset.
# RATELIMIT_STORAGE_URI=redis://:1234@localhost:6379/0
AUTH_LIMIT_PER_MINUTE=5 per minute
AUTH_LIMIT_PER_5_MINUTES=10 per 5 minutes
AUTH_LIMIT_PER_10_MINUTES=20 per 10 minutes
AUTH_LIMIT_PER_HOUR=50 per hour

# ===== JWT Settings =====
JWT_SECRET=mysupersecret
JWT_ALGORITHM=HS256
JWT_TOKEN_EXPIRY_HOURS=48

# ===== API Documentation =====
API_VERSION=1.0.0
API_VERSION_BASE=/v0/api
CONTACT_NAME=bicosteve
CONTACT_EMAIL=**
SENDGRID_API_KEY=
