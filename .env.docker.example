# ===== Flask & App =====
ENV=docker                     # Options: dev, prod, docker
DEBUG=True                  # True for dev, False for prod
HOST=0.0.0.0
PORT=5005

# ===== Database (MySQL) =====
DB_HOST=        # Use 'db' if running in Docker compose
DB_USER=
DB_PASSWORD=
DB_NAME=job-board-api
DB_PORT=3306

# ===== Redis =====
REDIS_HOST=redis        # Use 'redis' if running in Docker compose
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ===== JWT Settings =====
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_TOKEN_EXPIRY_HOURS=48

# ===== API Documentation =====
API_VERSION=1.0.0
API_VERSION_BASE=/job-board-api/v1/api
CONTACT_NAME=bicosteve
CONTACT_EMAIL=

# ===== Networking / Docker (optional) =====
SUBNET=172.25.0.0/24

SENDGRID_API_KEY=

HEALTHCHECK_PATH=/job-board-api/v1/api/health/check
